{
  "schema_version": 1,
  "id": "ip_cam",
  "name": "IP Cam",
  "menu": "Package: IP Cam",
  "version": "1.0.0",
  "description": "Downloads, caches and proxies JPEG, GIF and MJPEG images from IP cameras.",
  "author": "Martin Pihrt",
  "homepage": "https://github.com/martinpihrt/OSPy-plugins/tree/master/plugins/ip_cam",
  "license": "GPL-3.0",
  "ospy": {
    "min": "3.0.211"
  },
  "python": {
    "min": "3.8"
  },
  "requirements": [
    {
      "module": "requests",
      "package": "requests",
      "required": true
    },
    {
      "module": "PIL",
      "package": "Pillow",
      "required": true
    }
  ],
  "permissions": [
    "files",
    "network"
  ]
}
