{
  "schema_version": 1,
  "id": "relay_16",
  "name": "Direct 16 Relay Outputs",
  "version": "1.0.0",
  "author": "Martin Pihrt",
  "license": "GPL-3.0",
  "ospy": {
    "min_version": "3.0.211"
