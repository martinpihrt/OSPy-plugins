{
  "schema_version": 1,
  "id": "volt_temp_da",
  "name": "Voltage and Temperature Monitor",
  "version": "1.0.0",
  "author": "Martin Pihrt",
  "license": "GPL-3.0",
  "ospy": {
    "min_version": "3.0.211"
  },
  "python": {
    "min_version": "3.8"
  },
  "requirements": [
    {
      "module": "smbus",
      "package": "python3-smbus",
      "required": true
    }
  ],
  "hardware": {
